# Ollama runs locally and needs NO API key. These are optional overrides.
# You normally don't need a .env file at all with Ollama.

# Which pulled model to use (default: llama3.2)
# OLLAMA_MODEL=llama3.2

# Where Ollama is listening (default works for a standard install)
# OLLAMA_HOST=http://localhost:11434

# Where to write the SQLite log
# GUARDRAIL_DB=guardrail_logs.db
